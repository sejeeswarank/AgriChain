{
    "version": 2,
    "installCommand": "pnpm install",
    "buildCommand": "pnpm run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/send-email-otp",
            "destination": "/api/send-email-otp.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}