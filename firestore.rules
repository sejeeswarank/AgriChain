rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Private, only accessible by the owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Phone Mappings: Public Read (for login lookup), Auth Write (during signup)
    // CRITICAL: Login page needs to read this WITHOUT being logged in to find the email.
    match /phone_mappings/{phoneNumber} {
      allow get: if true; // Allow fetching specific document (lookup)
      allow list: if false; // Prevent listing all numbers
      allow write: if request.auth != null; // Created during signup
    }
  }
}
